# Build outputs
build/
filesystem/
*.z64
# Exception: the emulator page auto-loads /rom.z64 at boot, so we commit a
# prebuilt copy for the static site + local editor preview. All other
# .z64 outputs (e.g. star-crew-64.z64 from ./build-run) stay ignored.
!rom.z64
*.elf
*.o
*.d
*.dfs
*.pak
*.map

# Machine-local overrides for build-run.bat (e.g. ARES_EXE)
build-run.local.bat

# External toolchains (download with install.bat)
n64-toolchain/

# External libraries (non-submodule local clones)
libdragon/
tiny3d/

# Staged site for GitHub Pages
_site/

# IDE and editor files
.vscode/
*.swp
*.swo
*~
.idea/

# OS files
.DS_Store
Thumbs.db

# Claude Code
.claude/
*.n64
*.eeprom
*.ram
.history/
